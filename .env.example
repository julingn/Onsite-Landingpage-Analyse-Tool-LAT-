# evalu-pro — Konfiguration
# ──────────────────────────────────────────────────────────────────────────
# VERWENDUNG:
#   1. Diese Datei kopieren:  cp .env.example .env
#   2. Werte eintragen
#   3. .env liegt im Projektordner — router.php blockiert Browser-Zugriff
#
# Auf Railway: Variablen direkt im Dashboard eintragen (keine .env nötig)
# Auf VPS: .env-Datei auf dem Server ablegen (wird NICHT ins Git-Repo committed)
# ──────────────────────────────────────────────────────────────────────────

# ── KI-Provider ────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional, falls AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# ── Datenquellen ───────────────────────────────────────────────────────────
# DataForSEO (https://dataforseo.com)
DATAFORSEO_LOGIN=deine@email.de
DATAFORSEO_PASSWORD=dein-passwort

# Google PageSpeed Insights (optional — ohne Key ebenfalls nutzbar)
PAGESPEED_API_KEY=

# ── Google Search Console ─────────────────────────────────────────────────
# Service-Account-JSON: entweder als Base64 oder reines JSON (einzeilig)
# Base64 erzeugen (PowerShell):
#   [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("C:\pfad\service-account.json"))
GSC_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=sc-domain:example.com

# ── App-Login ──────────────────────────────────────────────────────────────
# Passwort-Hash erzeugen (PHP):
#   php -r "echo password_hash('deinPasswort', PASSWORD_DEFAULT);"
# Ohne diesen Eintrag gilt das Standardpasswort: evalupro2025
APP_PASSWORD_HASH=
