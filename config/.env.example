# ================================================================
# evalu-pro ó Umgebungsvariablen (Vorlage)
# ================================================================
# Auf Railway: Dashboard ? dein Service ? Variables ? Add Variable
# Lokal: Diese Datei als "config/.env" kopieren (wird nicht committed)
# Priorit‰t: Umgebungsvariable > app/settings.json > Default
# ================================================================

# -- KI-Provider -------------------------------------------------
# Aktiver Provider: "anthropic" oder "openai"
AI_PROVIDER=anthropic

# Modell-Auswahl (wird durch Settings-UI ¸berschrieben)
AI_MODEL=claude-sonnet-4-5

# Anthropic Claude ó https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI ó https://platform.openai.com/api-keys (optional)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1

# -- DataForSEO --------------------------------------------------
# Zugangsdaten unter https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# -- Google PageSpeed Insights ------------------------------------
# Optional ó ohne Key funktioniert PSI, aber mit Rate-Limit
# Key erstellen: https://console.cloud.google.com/apis/credentials
PAGESPEED_API_KEY=AIza...

# -- Google Search Console ----------------------------------------
# Service Account JSON als Base64-kodierten String ablegen:
#   base64 -w 0 service-account.json
# Service Account Docs: https://cloud.google.com/iam/docs/service-accounts
GSC_SERVICE_ACCOUNT_JSON=eyJ0eXBl...
GSC_SITE_URL=sc-domain:example.com

# -- App-Authentifizierung ----------------------------------------
# Passwort-Hash (bcrypt) f¸r den Login ó ¸berschreibt settings.json
# Hash erzeugen: php -r "echo password_hash('deinPasswort', PASSWORD_DEFAULT);"
# Leer lassen ? Default-Passwort "evalupro2025" wird verwendet
APP_PASSWORD_HASH=

# -- GitHub (f¸r dieses Repository) ------------------------------
# Nur f¸r lokale Git-Operationen nˆtig, nicht f¸r das Tool selbst
GITHUB_TOKEN=your_github_token_here
GITHUB_API_BASE=https://api.github.com
