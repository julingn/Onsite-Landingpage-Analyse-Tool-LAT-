# ----------------------------------------------
# LAT – Konfiguration (Vorlage)
# ----------------------------------------------
# Kopiere diese Datei als ".env" und trage deine echten Werte ein.
# Die Datei ".env" wird NICHT ins Repository committed (siehe .gitignore).
# ----------------------------------------------

# GitHub Personal Access Token (PAT)
# Erstellen unter: https://github.com/settings/tokens
# Benoetigte Berechtigungen: repo (oder nur public_repo fuer oeffentliche Repos)
GITHUB_TOKEN=your_github_token_here

# Optional: GitHub API Basis-URL (Standard: https://api.github.com)
GITHUB_API_BASE=https://api.github.com
